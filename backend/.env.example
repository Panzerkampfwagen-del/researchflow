GROQ_API_KEY=
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql+asyncpg://researchflow:password@localhost:5432/researchflow
# Default: general-purpose local encoder (384-dim). The SPECTER-fine-tuned drop-in
# is a path swap (same 384-dim, no DB migration) after running
# `python training/finetune_encoder.py`:  EMBEDDING_MODEL=models/minilm-specter-ft
EMBEDDING_MODEL=all-MiniLM-L6-v2
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_EXTRACTION_MODEL=llama-3.1-8b-instant
ANTHROPIC_FALLBACK_MODEL=claude-3-5-haiku-20241022
ARXIV_RATE_LIMIT_SECONDS=3
SEMANTIC_SCHOLAR_RATE_LIMIT_SECONDS=1
MAX_PAPERS_PER_QUERY=30
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=20
